# Supabase project Connect dialog
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key

# Secret service-role key (Supabase → Project Settings → API → service_role).
# SERVER-ONLY — no NEXT_PUBLIC_ prefix. Required for the team admin page to
# invite members and change roles. Never expose this to the browser or commit it.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Local app URL; replace with the production URL when deployed
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Daily Drop calendar day (defaults to Africa/Nairobi)
# DAILY_TIMEZONE=Africa/Nairobi

# Crisis risk detection — Groq LLM second pass (optional but recommended)
# Free tier: https://console.groq.com → API Keys
GROQ_API_KEY=
# Optional; defaults to llama-3.1-8b-instant
# GROQ_MODEL=llama-3.1-8b-instant
